# ========== Sealed Interface Changelog Types ==========

union ComponentChangelog = NoneChangelog | AggregatedChangelog

type NoneChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	firstRelease: ReleaseInfo!
	lastRelease: ReleaseInfo!
	branches: [NoneBranchChanges!]!
}

type AggregatedChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	firstRelease: ReleaseInfo!
	lastRelease: ReleaseInfo!
	branches: [AggregatedBranchChanges!]!
	sbomChanges: SbomChangesWithAttribution!
	findingChanges: FindingChangesWithAttribution!
}

type ReleaseInfo {
	uuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
}

type NoneBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	releases: [NoneReleaseChanges!]!
	changeType: ChangeType
}

type AggregatedBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	firstReleaseUuid: ID
	firstVersion: String
	lastReleaseUuid: ID
	lastVersion: String
	commitsByType: [CommitsByType!]!
	changeType: ChangeType
}

type CommitsByType {
	changeType: String!
	commits: [CodeCommit!]!
}

type NoneReleaseChanges {
	releaseUuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
	commits: [CodeCommit!]!
	sbomChanges: ReleaseSbomChanges!
	findingChanges: ReleaseFindingChanges!
}

type CodeCommit {
	commitId: String
	commitUri: String
	message: String!
	author: String
	email: String
	changeType: String!
}

type ReleaseSbomArtifact {
	purl: String!
	name: String
	version: String
}

type ReleaseSbomChanges {
	addedArtifacts: [ReleaseSbomArtifact!]!
	removedArtifacts: [ReleaseSbomArtifact!]!
}

type ReleaseVulnerabilityInfo {
	vulnId: String!
	purl: String
	severity: String
	aliases: [VulnerabilityAlias!]
	analysisState: AnalysisState
}

type ReleaseViolationInfo {
	type: String!
	purl: String
	analysisState: AnalysisState
}

type ReleaseWeaknessInfo {
	cweId: String!
	severity: String
	ruleId: String
	location: String
	analysisState: AnalysisState
}

type ReleaseFindingChanges {
	appearedCount: Int!
	resolvedCount: Int!
