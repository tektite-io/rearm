	outputTriggers: [ReleaseOutputEvent]
	identifiers: [Identifier]
	repoPath: String
	authentication: ComponentAuthentication
	branchSuffixMode: BranchSuffixMode
	globalInputEventRefs: [GlobalInputEventRef]
	perspectiveDetails: [Perspective]
	"""Component-level sid override (null = INHERIT)."""
	sidPurlOverride: SidPurlOverride
	"""Component-level decoded authority segments (null/empty = none stored)."""
	sidAuthoritySegments: [String!]
	"""Internal/external classification (D16). Null on legacy rows is treated as INTERNAL."""
	isInternal: BelongsToOrganization
}

enum ComponentKind {
	HELM
	GENERIC
}

